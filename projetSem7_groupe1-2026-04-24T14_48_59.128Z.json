          "parameters": {
            "code": "\n  const now = new Date();\n  const fiveMinutesAgo = new Date(now.getTime() - 5 * 60 * 1000);\n\n  // Parcourir chaque patient dans data.rows\n  for (const patient of input.rows) {\n    if (!patient.created_at) {\n      console.warn(\"Patient sans created_at :\", patient);\n      return false; // ou selon votre logique, on peut considérer comme invalide\n    }\n    const createdDate = new Date(patient.created_at);\n    if (createdDate < fiveMinutesAgo) {\n      // Ce patient a été créé il y a plus de 5 minutes\n      return false;\n    }\n  }\n  // Tous les patients ont été créés dans les 5 dernières minutes\n  return true;\n\n"
